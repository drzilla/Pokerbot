{
  "_meta": {
    "source": "GTOW_MTT_Complete_Reference.html (scraped 2026-05-30)",
    "base_url": "https://app.gtowizard.com/solutions",
    "required_params": [
      "gametype",
      "depth",
      "solution_type=gwiz",
      "soltab=strategy",
      "history_spot"
    ],
    "depth_suffix": ".125 REQUIRED on all depth and stack values",
    "stack_order": "UTG first, clockwise to BB",
    "preflop_actions_codes": {
      "F": "Fold",
      "C": "Call",
      "X": "Check",
      "R_n": "Raise to n BB (e.g. R2, R2.1). Exact size required per position/depth.",
      "RAI": "All-in (no amount suffix). Literal string RAI."
    },
    "history_spot": "count of tokens in preflop_actions (0=root). hs = len(pf_actions.split(\"-\")) if pf_actions else 0",
    "board_format": "rank+lowercase_suit no separators (e.g. QhQd2dTh)",
    "postflop_bet_encoding": "flop_actions/turn_actions: R{n} in BB (NOT pot fraction). X=check, C=call, F=fold.",
    "depth_snapping": "Invalid depth silently snaps nearest. ICM+wrong depth may fall back to session. Always use exact grid values.",
    "stacks_matching": "Must exactly match a DB row. Invalid stacks -> silent fallback. Omit stacks to let GTOW pick default.",
    "street_linking": {
      "flop_root": "board=XxYyZz + history_spot=(pf_action_count). No flop_actions needed.",
      "turn_root": "board=4cards + flop_actions + history_spot=(pf+flop counts). MUST include flop_actions.",
      "river_root": "board=5cards + flop+turn_actions + history_spot=(all counts). MUST include all prior.",
      "rule": "history_spot controls street, NOT board card count. Extra cards ignored if hs too low."
    },
    "multiway": {
      "max_players_postflop": 3,
      "four_way": "NOT supported",
      "action_order": "Positional (earliest position first)",
      "encoding": "Same X/R/C/F codes. Each action increments history_spot by 1."
    },
    "sb_behavior": "SB often has Call option. SB open: R2.5@15bb, R3@25-35bb, R3.5@100bb."
  },
